{
  "id": "file-metrics",
  "name": "File Metrics",
  "description": "Code complexity metrics — lines of code, function count, import analysis, and file size stats",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "excludeDirs": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["node_modules", ".git", "dist", "build", "vendor", "__pycache__"],
        "description": "Directories to exclude"
      },
      "maxFileSize": {
        "type": "number",
        "default": 500,
        "description": "Flag files larger than this many lines"
      }
    }
  }
}
