{
  "id": "snippet-store",
  "name": "Snippet Store",
  "description": "Save, search, and recall reusable code snippets across sessions",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "storeDir": {
        "type": "string",
        "description": "Directory to store snippets (defaults to ~/.openclaw/snippets)"
      },
      "maxSnippets": {
        "type": "number",
        "default": 500,
        "description": "Maximum number of stored snippets"
      }
    }
  }
}
