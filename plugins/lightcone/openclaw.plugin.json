{
  "id": "lightcone",
  "name": "Lightcone",
  "description": "Cloud browser and desktop automation via Lightcone's Northstar computer-use model",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "Lightcone API key (or set TZAFON_API_KEY env var)"
      },
      "defaultMaxSteps": {
        "type": "number",
        "default": 50,
        "description": "Default max steps for browse tasks"
      },
      "defaultKind": {
        "type": "string",
        "enum": ["browser", "desktop"],
        "default": "browser",
        "description": "Default session type"
      }
    }
  },
  "uiHints": {
    "apiKey": {
      "label": "API Key",
      "placeholder": "sk_...",
      "sensitive": true
    }
  }
}
