{
  "id": "n8nac",
  "name": "n8n-as-code",
  "description": "Build, update, validate, and manage n8n workflows conversationally. 537 node schemas, 10k+ properties, 1,243 doc pages — zero hallucination.",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "n8nHost": {
        "type": "string",
        "description": "n8n instance URL"
      },
      "n8nApiKey": {
        "type": "string",
        "description": "n8n API key"
      },
      "workspaceDir": {
        "type": "string",
        "default": "~/.openclaw/n8nac",
        "description": "Directory for workflow files and config"
      }
    }
  },
  "uiHints": {
    "n8nHost": {
      "label": "n8n Host URL",
      "placeholder": "https://your-n8n.example.com"
    },
    "n8nApiKey": {
      "label": "n8n API Key",
      "sensitive": true
    }
  },
  "skills": ["./skills/n8n-architect"]
}
